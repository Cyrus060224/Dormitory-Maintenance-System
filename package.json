{
  "name": "dorm-repair-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:fastapi",
    "dev:fastapi": "concurrently \"npm run dev:backend-fastapi\" \"npm run dev:frontend\"",
    "dev:express": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "start": "cross-env NODE_ENV=production npm run start:backend",
    "start:backend": "cd backend && npm run start",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "typecheck": "cd frontend && npm run typecheck",
    "typecheck:build": "cd frontend && npm run typecheck:build",
    "lint": "cd frontend && npm run lint --",
    "db:push": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 npx drizzle-kit push",
    "dev:backend": "cd backend && npm run dev",
    "dev:backend-fastapi": "cd backend_fastapi && python -m uvicorn main:app --reload --port 8000",
    "dev:frontend": "cd frontend && npm run dev",
    "clean": "rimraf frontend/dist backend/dist",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/express": "^5.0.1",
    "@types/multer": "^1.4.12",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.9.0",
    "globals": "^15.9.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.62.0",
    "@aws-sdk/client-s3": "^3.668.0",
    "@aws-sdk/client-ses": "^3.668.0",
    "@aws-sdk/s3-request-presigner": "^3.668.0",
    "@google/generative-ai": "^0.24.1",
    "@sendgrid/mail": "^8.1.4",
    "@supabase/supabase-js": "^2.49.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@vercel/postgres": "^0.10.0",
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.1",
    "drizzle-orm": "^0.43.1",
    "drizzle-zod": "^0.7.1",
    "express": "^4.18.2",
    "form-data": "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "mailgun.js": "^10.2.1",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.9",
    "openai": "^4.104.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "postgres": "^3.4.5",
    "resend": "^4.0.0",
    "stripe": "^19.1.0",
    "zod": "^3.24.4"
  }
}
