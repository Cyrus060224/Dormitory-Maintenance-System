# Dorm Repair System environment example
# Copy this file to .env and change values as needed.

# --- 后端配置 (FastAPI) ---
# JWT 密钥（生产环境请使用强随机字符串）
JWT_SECRET=dorm-repair-secret-key-change-in-production
TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# DB_PATH=backend_fastapi/dorm.db

# --- 前端配置 ---
# API 基础地址（生产环境填写完整 URL）
# VITE_API_BASE_URL=http://127.0.0.1:8000

# --- Express/PostgreSQL backend (legacy optional path) ---
# PORT=3001
# FRONTEND_URL=http://localhost:5173
# DATABASE_URL=postgres://user:password@localhost:5432/dorm_db
