# ============================================
# 宿舍报修系统 - 环境变量配置示例
# 复制此文件为 .env 并填入实际配置值
# ============================================

# --- 后端配置 (Express) ---
# 服务器端口
PORT=3001

# JWT 密钥（生产环境请使用强随机字符串）
JWT_SECRET=dorm-repair-secret-key-change-in-production

# 前端地址（用于 CORS）
FRONTEND_URL=http://localhost:5173

# --- 数据库配置 (Express 后端使用，远程数据库) ---
# 如果使用远程数据库，取消注释并填写
# DATABASE_URL=postgres://user:password@localhost:5432/dorm_db

# --- 前端配置 ---
# API 基础地址（生产环境填写完整 URL）
# VITE_API_BASE_URL=http://127.0.0.1:8000
